{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:railway": "NODE_ENV=production next build",
    "start": "next start",
    "start:railway": "NODE_ENV=production next start -p $PORT",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "analyze": "ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "railway:deploy": "railway up --service frontend",
    "railway:logs": "railway logs --service frontend",
    "railway:shell": "railway shell frontend",
    "railway:vars": "railway variables --service frontend",
    "railway:status": "railway status --service frontend",
    "railway:build": "railway run --service frontend npm run build:railway",
    "railway:start": "railway run --service frontend npm run start:railway",
    "railway:test": "railway run --service frontend npm run test",
    "railway:lint": "railway run --service frontend npm run lint",
    "railway:type-check": "railway run --service frontend npm run type-check"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "html5-qrcode": "^2.3.8",
    "js-cookie": "^3.0.5",
    "next": "15.4.6",
    "qr-scanner": "^1.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "swr": "^2.2.4",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/testing-library__jest-dom": "^5.14.9",
    "eslint": "^9.33.0",
    "eslint-config-next": "^15.4.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
